# ── Supabase (obligatoire) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Application (obligatoire en production) ────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Email — Resend (optionnel) ─────────────────────────────
# Sans RESEND_API_KEY, les invitations fonctionnent via lien
# affiché dans l'interface, mais aucun email n'est envoyé.
# RESEND_API_KEY=re_xxxxx
# EMAIL_FROM=Amicale <noreply@your-domain.fr>
